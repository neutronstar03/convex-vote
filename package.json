{
  "name": "convex-vote",
  "type": "module",
  "version": "1.0.2",
  "private": true,
  "author": "neutronstar03",
  "repository": "https://github.com/neutronstar03/convex-vote",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "preview:cf": "bun run build && cp -R functions ./build/client/functions && wrangler pages dev ./build/client",
    "deploy:cf": "bun run build && cp -R functions ./build/client/functions && wrangler pages deploy ./build/client --project-name=convex-vote --branch=main"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@snapshot-labs/snapshot.js": "^0.14.20",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.72.0",
    "react-router": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.6",
    "wagmi": "^3.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@cloudflare/workers-types": "^4.20260412.1",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wrangler": "^4.81.1"
  }
}
